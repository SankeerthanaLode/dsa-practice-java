class Solution {
    public int maximumWealth(int[][] accounts) {

        int max_wealth = 0;
        int sum = 0;
        int rows = accounts.length;
        int cols = accounts[0].length;

        for(int i = 0; i < rows; i++){ 
            sum = 0;
            for(int j = 0; j < cols; j++){
                sum = sum + accounts[i][j];
            }
            max_wealth = Math.max(max_wealth, sum);
        }

        return max_wealth;
    }
}
