class Solution {

    static int count_digits(int num){
        int digits = 0;

        while(num != 0){
            digits++;
            num = num/10;
        }
        return digits;
    }

    public int findNumbers(int[] nums) {
        int count = 0;
        int digits;

        for(int i = 0; i < nums.length; i++){
            digits = count_digits(nums[i]);
            
            if(digits % 2 == 0){
                count++;
            }
        }

        return count;
    }
}
