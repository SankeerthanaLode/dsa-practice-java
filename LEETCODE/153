class Solution {
    public int findMin(int[] nums) {
        int i = 0;

        if(nums.length == 1){
            return nums[0];
        }
        
        while(i < nums.length){
            if(nums[i] > nums[(i + 1)%nums.length]){
                return nums[(i + 1)%nums.length];
            }
            i = (i + 1)%nums.length;
        }

        return -1;
    }
}
