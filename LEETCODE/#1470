class Solution {
    public int[] shuffle(int[] nums, int n) {
        int[] ans = new int[2*n];

        int first = 0;
        int second = n;

        for(int i = 0; i < 2*n; i+=2){
            ans[i] = nums[first++];
            ans[i+1] = nums[second++];
        }

        return ans;

    }
}
