class Solution {
    public int maxSubArray(int[] nums) {
        int current = 0;
        int max = Integer.MIN_VALUE;

        for(int num : nums){
            if(current < 0){
                current = 0;
            }

            current += num;

            if(max < current){
                max = current;
            }
        }

        return max;
    }
}
