class Solution {
    public int maxProfit(int[] prices) {
        int maxProfit = 0;

        int minPrice = prices[0];

        int i = 1;
        while(i < prices.length){
            if(minPrice > prices[i]){
                minPrice = prices[i];
            }else{
                if(maxProfit < prices[i] - minPrice){
                    maxProfit = prices[i] - minPrice;
                }
            }

            i++;
        }

        return maxProfit;
    }
}
