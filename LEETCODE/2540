class Solution {
    public int getCommon(int[] nums1, int[] nums2) {
        int i = 0;
        int j = 0;
        int min = Integer.MAX_VALUE;

        while(i < nums1.length && j < nums2.length){
            if(nums1[i] == nums2[j]){
                min = nums1[i];
                return min;
            }else if(nums1[i] > nums2[j]){
                j++;
            }else{
                i++;
            }
        }  

       return -1;
        
    }
}
