class Solution {
    public int distributeCandies(int[] candyType) {
        HashSet<Integer> set = new HashSet<>();
        int num;
        int max = candyType.length/2;
        for(int i = 0; i < candyType.length; i++){
            num = candyType[i];
            set.add(num);
        }

        if(set.size() >= max){
            return max;
        }else{
            return set.size();
        }
    }
}
