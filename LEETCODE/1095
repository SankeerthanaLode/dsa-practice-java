/**
 * // This is MountainArray's API interface.
 * // You should not implement it, or speculate about its implementation
 * interface MountainArray {
 *     public int get(int index) {}
 *     public int length() {}
 * }
 */
 
class Solution {
    public int findInMountainArray(int target, MountainArray mountainArr) {
        int start = 0;
        int end = mountainArr.length() - 1;
        int mid;

        while(start < end){
            mid = (start + end)/2;

            if(mountainArr.get(mid) > mountainArr.get(mid + 1)){
                end = mid;
            }else{
                start = mid + 1;
            }
        }

        int idx = binSearch(target, mountainArr, 0, end);
        if(idx == -1){
            idx = binSearchDecreasing(target, mountainArr, end + 1, mountainArr.length() - 1);
        }

        return idx;
    }

    int binSearch(int target, MountainArray mountainArr, int start, int end){
        int mid;

        while(start <= end){
            mid = (start + end)/2;

            if(mountainArr.get(mid) == target){
                return mid;
            }else if(mountainArr.get(mid) > target){
                end = mid - 1;
            }else{
                start = mid + 1;
            }
        }

        return -1;
    }

    int binSearchDecreasing(int target, MountainArray mountainArr, int start, int end){
        int mid;

        while(start <= end){
            mid = (start + end)/2;

            if(mountainArr.get(mid) == target){
                return mid;
            }else if(mountainArr.get(mid) > target){
                start = mid + 1;
            }else{
                end = mid - 1;
            }
        }

        return -1;
    }
}
