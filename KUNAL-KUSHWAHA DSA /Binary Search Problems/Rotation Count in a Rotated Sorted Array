class Solution {
    public int findKRotation(int arr[]) {
        // Code here
        if(arr[0] < arr[arr.length - 1]){
            return 0;
        }
        
        if(arr.length == 1){
            return 0;
        }
        
        int i = 0;
        
        while(i < arr.length - 1){
            if(arr[i] < arr[i + 1]){
                i++;
            }else{
                break;
            }
        }
        
        return i+1;
    }
} 
