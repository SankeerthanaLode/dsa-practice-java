class Solution {
    public int fib(int n) {
        int val;
        val = fibo(n);

        return val;
    }

    static int fibo(int n){
        int sum;

        if(n == 0){
            return 0;
        }

        if(n == 1){
            return 1;
        }

        sum = fibo(n-1) + fibo(n-2);
        return sum;
    }
}
