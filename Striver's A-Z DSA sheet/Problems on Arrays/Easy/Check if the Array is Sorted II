class Solution {
    public boolean check(int[] nums) {
        int i = 0;
        int count = 0;

        while(i < nums.length){
            if(nums[i] > nums[(i+1)%nums.length]){
                count++;
            }
            i++;
        }

        if(count == 1 || count == 0){
            return true;
        }else{
            return false;
        }
    }
}
