class Solution {
    public int reverse(int x) {
        long rev = 0;
        int num;

        while(x != 0){
            num = x%10;
            rev = (rev*10) + (long)num;
            x /= 10;
        }

        if(rev < -2147483648 || rev > 2147483647){
            return 0;
        }

        return (int)rev;
    }
}
