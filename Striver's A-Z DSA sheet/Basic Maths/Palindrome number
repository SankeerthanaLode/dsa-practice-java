class Solution {
    public boolean isPalindrome(int x) {
        int rev = 0;
        int num;
        int temp = x;

        if(x < 0){
            return false;
        }

        while(x != 0){
            num = x%10;
            rev = (rev*10) + num;
            x = x/10;
        }

        if(rev == temp){
            return true;
        }else{
            return false;
        }
    }
}
