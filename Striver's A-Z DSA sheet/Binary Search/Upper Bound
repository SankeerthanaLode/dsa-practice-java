class Solution {
    public int upperBound(int[] nums, int x) {
        int start = 0;
        int end = nums.length - 1;
        int mid;

        while(start < end){
            mid = start + (end - start)/2;

            if(nums[mid] <= x){
                start = mid + 1;
            }else{
                end = mid;
            }
        }

        return end;
    }
}
